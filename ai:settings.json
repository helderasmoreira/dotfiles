{
  "permissions": {
    "allow": [
      "Read(~/Work/Carwow/claude-docs/**)",
      "Read(~/.claude/**)",
      "Bash(gh pr view)",
      "Bash(gh pr view *)",
      "Bash(gh pr list)",
      "Bash(gh pr list *)",
      "Bash(gh pr diff)",
      "Bash(gh pr diff *)",
      "Bash(gh pr checks)",
      "Bash(gh pr checks *)",
      "Bash(gh pr status)",
      "Bash(gh pr status *)",
      "Bash(bundle show *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git show)",
      "Bash(git show *)",
      "Bash(git blame *)",
      "Bash(carwow run bundle exec rspec *)",
      "Bash(carwow run bundle exec rubocop *)",
      "WebFetch(domain:rubyllm.com)",
      "mcp__launchdarkly__get-flag",
      "mcp__claude_ai_Slack__slack_search_public_and_private"
    ],
    "deny": [
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)"
    ],
    "ask": [
      "Read(**/.env*)",
      "Bash(git push:*)",
      "Bash(gh pr create:*)"
    ]
  },
  "model": "claude-fable-5[1m]",
  "enabledPlugins": {
    "core@carwow-factory": true,
    "ruby-lsp@claude-plugins-official": true,
    "sre@carwow-factory": true
  },
  "extraKnownMarketplaces": {
    "carwow-factory": {
      "source": {
        "source": "git",
        "url": "git@github.com:carwow/factory.git"
      }
    }
  },
  "skipWorkflowUsageWarning": true
}
